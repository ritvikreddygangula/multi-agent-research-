# Django core
SECRET_KEY=generate-a-long-random-string-here
DEBUG=False

# Comma-separated list of allowed hostnames (no protocol/port)
# e.g. myapp.railway.app,api.myapp.com
ALLOWED_HOSTS=localhost,127.0.0.1

# Database — leave unset to use SQLite locally
# Production: set to your PostgreSQL URL (Railway / Neon / Supabase / etc.)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# CORS — comma-separated full origins (include protocol)
# e.g. https://myapp.vercel.app,https://www.myapp.com
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Per-user token budget (default 100 000 tokens ≈ ~$0.10 gpt-4o-mini / ~$1.50 gpt-4o)
DEFAULT_TOKEN_LIMIT=100000

# External API keys (all required)
OPENAI_API_KEY=sk-...
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=research-memory
TAVILY_API_KEY=tvly-...
